# zkDNSSEC-Stellar environment configuration
#
# RISC0 prover mode: 'local' (default, CPU), 'bonsai' (Bonsai network), or 'dev' (mock)
RISC0_PROVER=local

# Bonsai API key (only needed when RISC0_PROVER=bonsai)
# BONSAI_API_KEY=

# Stellar testnet deployer secret key (generate one at https://developers.stellar.org/docs/tools/lab)
STELLAR_SECRET_KEY=

# Stellar network (testnet | futurenet | mainnet)
STELLAR_NETWORK=testnet

# Soroban RPC endpoint
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract addresses (filled in after scripts/deploy.sh)
ZKDNSSEC_CONTRACT_ID=
RISC0_VERIFIER_CONTRACT_ID=

# Path to the Groth16 fixture generated by scripts -- --prove groth16
ZKDNSSEC_FIXTURE_PATH=./contracts/fixtures/groth16-fixture.json
